# El Monstruo — Kernel Dockerfile
# Sprint 1 — fix aplicado 2026-04-13 por recomendación del Consejo de Sabios
# Cambios: run.py wrapper (evita shell expansion), CACHE_BUST, renombrado a .web
# Deploy target: Railway

FROM python:3.12-slim AS base

# Cache bust — cambiar este valor fuerza rebuild completo
ARG CACHE_BUST=sp882_fonts_liberation_dejavu

WORKDIR /app

# System deps for asyncpg, pgvector native extensions, healthcheck, and Playwright chromium
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    build-essential \
    libpq-dev \
    # Playwright chromium system dependencies
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    # Sprint 88.2 d (2026-05-07): fonts del sistema para Chromium headless.
    # Sin estas, Chromium renderiza texto con fallback null = invisible.
    # Bug raiz Sprint 88.1: screenshots de Playwright en Railway capturaban
    # layout pero TODO TEXTO INVISIBLE porque no hay fuentes en el container.
    fonts-liberation \
    fonts-dejavu-core \
    fonts-noto-core \
    fontconfig \
    && rm -rf /var/lib/apt/lists/* \
    && fc-cache -f

# Python deps — production only (eval deps in requirements-eval.txt)
# Excludes: pytest, garak, ragas (they pull torch/transformers ~2GB)
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    grep -v "^#" requirements.txt | \
    grep -v "^$" | \
    grep -v "pytest" | \
    pip install --no-cache-dir -r /dev/stdin

# Install Playwright chromium browser (SP11 — Browser Automation)
# Must run AFTER pip install (playwright package must be installed first)
RUN pip install playwright==1.49.0 && playwright install chromium

# App code
COPY . .

# Environment
ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Health check (hardcoded 8000 — Railway overrides PORT at runtime, run.py handles it)
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

EXPOSE 8000

# Wrapper Python lee PORT desde env — CERO dependencia de shell expansion
CMD ["python", "run.py"]
