# El Monstruo — .gitignore

# Environment
.env
.env.local
.env.production

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker
langfuse-data/

# OS
.DS_Store
Thumbs.db

# Testing
.coverage
htmlcov/
.pytest_cache/

# Logs
*.log
logs/
# Setup transitorio de la radar (scratch local)
.biblia-radar-setup/
.venv-test/

# CDP scripts y secrets temporales (DSC-S-001) - NO versionar
.cdp_*
.meta_*
.bw_*
.tmp_*
rls_audit_report.md
rls_audit_continuous_report.md

# D-2 (DSC-S-013): snapshots forenses pesados se suben a CDN, no al repo.
# Solo el sidecar .meta.json y el .pointer.json se commiten para trazabilidad.
discovery_forense/SNAPSHOTS/*.gz

# Manus working artifacts (commit message drafts) — NO versionar
.commit_msg_*.txt

# Claude Code worktrees (workspaces temporales de Cowork local) — NO versionar
# Ref: H11 housekeeping (auditoría 17-may-2026)
.claude/

# forja-mcp es un repositorio Git INDEPENDIENTE (MCP Gateway en Railway)
# clonado dentro de el-monstruo para conveniencia de desarrollo local.
# NO debe versionarse aquí (su trabajo vive en su propio repo y deploy).
# Ref: H11 housekeeping (auditoría 17-may-2026)
forja-mcp/

# THREAD-IMMUNITY-GATE-v1: receipts locales runtime (no commitear)
# Cada sesión escribe bridge/thread_immunity/<uuid>/startup_receipt.json en runtime.
# Solo se commitea el .gitkeep para preservar el directorio.
bridge/thread_immunity/*/
!bridge/thread_immunity/.gitkeep
.venv-s91/
