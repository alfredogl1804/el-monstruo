# El Monstruo — .gitignore

# Environment
.env
.env.local
.env.production

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker
langfuse-data/

# OS
.DS_Store
Thumbs.db

# Testing
.coverage
htmlcov/
.pytest_cache/

# Logs
*.log
logs/
# Setup transitorio de la radar (scratch local)
.biblia-radar-setup/
.venv-test/

# CDP scripts y secrets temporales (DSC-S-001) - NO versionar
.cdp_*
.meta_*
.bw_*
.tmp_*
rls_audit_report.md
rls_audit_continuous_report.md

# D-2 (DSC-S-013): snapshots forenses pesados se suben a CDN, no al repo.
# Solo el sidecar .meta.json y el .pointer.json se commiten para trazabilidad.
discovery_forense/SNAPSHOTS/*.gz
