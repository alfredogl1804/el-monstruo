{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Real Loop Chain Manifest",
  "description": "Defines the configuration and metadata of a Vigilia Sincrónica chain execution.",
  "type": "object",
  "required": [
    "chain_id",
    "chain_version",
    "created_at",
    "created_by",
    "steps",
    "max_autonomy_level",
    "risk_controls",
    "state_fabric_delta_path"
  ],
  "properties": {
    "chain_id": {
      "type": "string",
      "description": "Unique identifier for this chain execution."
    },
    "chain_version": {
      "type": "string",
      "description": "Version of the chain contract (e.g., v0.2.0)."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of chain creation."
    },
    "created_by": {
      "type": "string",
      "description": "Sprint or process that created this chain."
    },
    "steps": {
      "type": "array",
      "description": "Ordered list of steps in the chain.",
      "items": {
        "type": "object",
        "required": ["step_id", "loop_id", "action", "expected_outputs"],
        "properties": {
          "step_id": { "type": "integer" },
          "loop_id": { "type": "string" },
          "action": { "type": "string" },
          "expected_outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "max_autonomy_level": { "type": "string" },
          "depends_on_step": { "type": ["integer", "null"] }
        }
      }
    },
    "max_autonomy_level": {
      "type": "string",
      "description": "Global maximum autonomy for the entire chain."
    },
    "risk_controls": {
      "type": "object",
      "required": ["not_realtime_verified", "no_m2_unlock", "no_daemon", "no_external_api"],
      "properties": {
        "not_realtime_verified": { "type": "boolean" },
        "no_m2_unlock": { "type": "boolean" },
        "no_daemon": { "type": "boolean" },
        "no_external_api": { "type": "boolean" }
      }
    },
    "state_fabric_delta_path": {
      "type": "string",
      "description": "Path to the isolated event log delta for this chain."
    }
  }
}
