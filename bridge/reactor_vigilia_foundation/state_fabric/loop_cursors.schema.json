{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loop Cursors Schema v0",
  "type": "object",
  "patternProperties": {
    "^[a-zA-Z0-9_]+$": {
      "type": "object",
      "properties": {
        "last_event_id": { "type": "integer" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["last_event_id", "updated_at"]
    }
  }
}
