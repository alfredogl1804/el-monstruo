{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Decisions Pending Schema v0",
  "type": "object",
  "properties": {
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "t1_status": { 
            "type": "string",
            "enum": ["PENDING", "SIGNED", "REJECTED", "SUPERSEDED"]
          },
          "context_ref": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "signed_at": { "type": ["string", "null"], "format": "date-time" }
        },
        "required": ["id", "description", "t1_status", "created_at"]
      }
    }
  },
  "required": ["decisions"]
}
