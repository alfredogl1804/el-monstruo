{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post-M2 Reclassification Manifest",
  "description": "Top-level manifest for the reclassification sprint execution.",
  "type": "object",
  "required": ["manifest_id", "sprint_id", "timestamp_utc", "inputs_verified", "outputs_generated", "gates_passed", "verdict"],
  "properties": {
    "manifest_id": { "type": "string" },
    "sprint_id": { "type": "string", "const": "SPR-ORACLE-POST-M2-RISK-RECLASSIFICATION-001" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "inputs_verified": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs_generated": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gates_passed": { "type": "integer" },
    "gates_total": { "type": "integer", "const": 14 },
    "verdict": { "type": "string", "enum": ["PASS", "PASS_WITH_FINDINGS", "FAIL"] },
    "new_api_calls_made": { "type": "boolean", "const": false },
    "secrets_accessed": { "type": "boolean", "const": false },
    "scheduler_enabled": { "type": "boolean", "const": false },
    "supabase_moved": { "type": "boolean", "const": false }
  }
}
