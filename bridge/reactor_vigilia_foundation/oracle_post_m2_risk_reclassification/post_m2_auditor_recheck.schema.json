{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post-M2 Auditor Recheck",
  "description": "Gate log for the 14-gate validation of the reclassification.",
  "type": "object",
  "required": ["recheck_id", "sprint_id", "timestamp_utc", "gates", "total_pass", "total_fail", "verdict"],
  "properties": {
    "recheck_id": { "type": "string" },
    "sprint_id": { "type": "string" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_id", "gate_name", "result", "evidence"],
        "properties": {
          "gate_id": { "type": "integer" },
          "gate_name": { "type": "string" },
          "result": { "type": "string", "enum": ["PASS", "FAIL"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "total_pass": { "type": "integer" },
    "total_fail": { "type": "integer" },
    "verdict": { "type": "string", "enum": ["PASS", "PASS_WITH_FINDINGS", "FAIL"] }
  }
}
