{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post-M2 T1 Decision Pack",
  "description": "Structured decision pack for T1 approval after reclassification.",
  "type": "object",
  "required": ["pack_id", "sprint_id", "timestamp_utc", "decisions", "recommendation"],
  "properties": {
    "pack_id": { "type": "string" },
    "sprint_id": { "type": "string" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision_id", "title", "options", "status"],
        "properties": {
          "decision_id": { "type": "integer" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "options": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": { "type": "string", "enum": ["T1_PENDING", "APPROVED", "REJECTED", "DEFERRED"] },
          "t1_response": { "type": ["string", "null"] }
        }
      }
    },
    "recommendation": { "type": "string" },
    "next_sprint_options": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
