{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Oracle M2 Validation Report",
  "description": "12-gate validation report for the M2 probe execution",
  "type": "object",
  "required": ["report_id", "sprint_id", "timestamp_utc", "gates", "verdict"],
  "properties": {
    "report_id": { "type": "string" },
    "sprint_id": { "type": "string" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate_id", "name", "result", "evidence"],
        "properties": {
          "gate_id": { "type": "integer" },
          "name": { "type": "string" },
          "result": { "type": "string", "enum": ["PASS", "FAIL"] },
          "evidence": { "type": "string" }
        }
      }
    },
    "verdict": { "type": "string", "enum": ["PASS", "PASS_WITH_FINDINGS", "FAIL"] },
    "pass_count": { "type": "integer" },
    "fail_count": { "type": "integer" },
    "findings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
