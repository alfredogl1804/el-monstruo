{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Realtime Capability",
  "description": "A single capability verified in real-time via API probe",
  "type": "object",
  "required": ["capability_id", "provider_id", "capability_type", "evidence_status", "verified_at_utc"],
  "properties": {
    "capability_id": { "type": "string" },
    "provider_id": { "type": "string" },
    "capability_type": {
      "type": "string",
      "enum": ["text_reasoning", "vision", "audio", "video", "tool_use", "web_search", "code_execution", "file_input", "long_context", "structured_outputs", "embeddings", "image_generation", "realtime_voice", "agents_background"]
    },
    "evidence_status": {
      "type": "string",
      "enum": ["REALTIME_VERIFIED", "STATIC_CATALOG", "DOC_VERIFIED", "ACCESS_BLOCKED"]
    },
    "model_id": { "type": "string" },
    "verified_at_utc": { "type": "string", "format": "date-time" },
    "raw_response_hash": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  }
}
