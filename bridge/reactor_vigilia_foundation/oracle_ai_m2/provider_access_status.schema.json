{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Provider Access Status",
  "description": "Summary of access status for all targeted providers",
  "type": "object",
  "required": ["sprint_id", "timestamp_utc", "providers"],
  "properties": {
    "sprint_id": { "type": "string" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider_id", "access_status", "key_available"],
        "properties": {
          "provider_id": { "type": "string" },
          "access_status": { "type": "string" },
          "key_available": { "type": "boolean" },
          "models_count": { "type": "integer" },
          "probe_calls_made": { "type": "integer" },
          "error_summary": { "type": ["string", "null"] }
        }
      }
    }
  }
}
