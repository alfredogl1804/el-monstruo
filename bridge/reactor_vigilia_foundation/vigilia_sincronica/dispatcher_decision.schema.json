{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dispatcher Decision Schema",
  "type": "object",
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "decision": { "type": "string", "enum": ["ACTIVATE_LOOP", "WAIT", "HALT"] },
    "target_loop": { "type": "string" },
    "reason": { "type": "string" }
  },
  "required": ["timestamp", "decision", "reason"]
}
