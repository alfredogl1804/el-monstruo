{
  "schema_version": "0.1.0",
  "schema_name": "t1_directive_queue",
  "description": "Schema for T1 Directive Queue — strategic guidance from Alfredo (T1) to embryos",
  "required_fields": [
    "directive_id",
    "created_at",
    "created_by",
    "source",
    "directive_type",
    "priority",
    "scope",
    "target_embryos",
    "focus",
    "desired_outcome",
    "forbidden_interpretations",
    "ttl_cycles",
    "expires_at",
    "status",
    "may_influence_scoring",
    "may_authorize_actions",
    "requires_dispatcher",
    "no_r1",
    "no_canon",
    "no_memory_write",
    "no_supabase",
    "evidence_ref",
    "t1_verbatim"
  ],
  "field_constraints": {
    "created_by": {"allowed_values": ["ALFREDO_T1"]},
    "source": {"allowed_values": ["manual_t1_input"]},
    "directive_type": {"allowed_values": ["FOCUS_SHIFT", "PRIORITY_BOOST", "PRIORITY_SUPPRESS", "WHAT_NOT_TO_DO", "STRATEGIC_GUIDANCE"]},
    "priority": {"min": 1, "max": 10},
    "scope": {"allowed_values": ["ALL_EMBRYOS", "SPECIFIC_EMBRYO", "PAIR"]},
    "target_embryos": {"type": "array", "min_length": 1},
    "status": {"allowed_values": ["ACTIVE", "EXPIRED", "SUPERSEDED", "PAUSED", "INVALID"]},
    "may_influence_scoring": {"must_be": true},
    "may_authorize_actions": {"must_be": false},
    "requires_dispatcher": {"must_be": true},
    "no_r1": {"must_be": true},
    "no_canon": {"must_be": true},
    "no_memory_write": {"must_be": true},
    "no_supabase": {"must_be": true}
  },
  "validation_rules": [
    "t1_verbatim MUST NOT be empty or null — directive without verbatim is INVALID",
    "may_authorize_actions MUST be false — directive cannot grant permissions",
    "no_r1 MUST be true — directive cannot unlock R1 operations",
    "forbidden_interpretations MUST be a non-empty array",
    "target_embryos MUST contain at least one valid embryo_id",
    "expires_at MUST be a valid ISO 8601 timestamp or null for indefinite",
    "ttl_cycles MUST be >= 1",
    "directive MUST NOT contain secrets, API keys, or credentials",
    "directive MUST NOT contain raw chain-of-thought from any LLM"
  ]
}
