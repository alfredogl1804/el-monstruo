{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event Log Contract v0.2",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "dispatcher_signature": {
      "type": "string"
    }
  },
  "required": ["event_id", "timestamp_utc", "actor", "action", "payload"]
}
