# ═══════════════════════════════════════════════════════════════════════════════
# El Monstruo — Environment Variables
# Copy to .env and fill in your values
# Updated: 2026-05-21 (Sprint 27 — SMS v3.1 + AUDN + Temporal)
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM API Keys (Los 6 Sabios + Routers) ──────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
SONAR_API_KEY=
COHERE_API_KEY=
OLLAMA_HOST=http://localhost:11434

# ── Supabase (Memory + State) ──────────────────────────────────────────────
SUPABASE_URL=https://xsumzuhwmivjgftsneov.supabase.co
SUPABASE_SERVICE_KEY=
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xsumzuhwmivjgftsneov.supabase.co:5432/postgres

# ── Sovereign Memory System (SMS) — CANONICAL (DSC-M-001) ─────────────────
# Auth key for SMS API endpoints (required in production)
SMS_API_KEY=
# AUDN evaluator (DeepSeek R1 via OpenRouter)
SMS_AUDN_ENABLED=true
SMS_AUDN_MODEL=deepseek/deepseek-r1-0528
# Embedding config
SMS_EMBEDDING_PROVIDER=openai
SMS_EMBEDDING_MODEL=text-embedding-3-small
SMS_EMBEDDING_DIMS=1536
# Behavior
SMS_ENABLED=true
SMS_CONFIDENCE_THRESHOLD=0.7
SMS_CRYSTAL_THRESHOLD=5
SMS_DECAY_RATE=0.05
SMS_MAX_AXIOMS_INJECT=10
SMS_RERANK_ENABLED=false
# Agent identity
SMS_AGENT_ID=manus-c
SMS_PROJECT_ID=el-monstruo
SMS_FRONT_ID=kernel
SMS_ACTOR_TYPE=agent

# ── Telegram Bot ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_AUTHORIZED_CHAT_IDS=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_GUARDIAN_CHAT_ID=
GUARDIAN_TELEGRAM_ALERTS=true

# ── Langfuse (Observability) ──────────────────────────────────────────────
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Browser / Browserless ─────────────────────────────────────────────────
BROWSERLESS_URL=
BROWSERLESS_TOKEN=
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# ── External APIs ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
ZEROENTROPY_API_KEY=
DEEPL_API_KEY=
DEEPL_ENABLED=false
GOOGLE_PSI_API_KEY=
NOTION_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Gmail / Google ────────────────────────────────────────────────────────
GMAIL_APP_PASSWORD=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GOOGLE_CALENDAR_CREDENTIALS=

# ── Slack ─────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# ── Railway / Deployment ──────────────────────────────────────────────────
KERNEL_BASE_URL=https://el-monstruo-kernel-production.up.railway.app
KERNEL_HEALTH_URL=https://el-monstruo-kernel-production.up.railway.app/health
MONSTRUO_ENV=production
MONSTRUO_API_KEY=
COMMAND_CENTER_API_KEY=
JWT_SECRET=

# ── Embrión (Autonomous Loop) ─────────────────────────────────────────────
EMBRION_CHECK_INTERVAL=60
EMBRION_DAILY_BUDGET_USD=5.0
EMBRION_CAP_PER_LATIDO_USD=0.50
EMBRION_ACTOR_MODEL=gpt-4.1
EMBRION_JUDGE_MODEL=deepseek/deepseek-r1-0528
EMBRION_LATIDO_AUTONOMO_ENABLED=true
EMBRION_USE_MAGNA_ROUTER=false
EMBRION_CATASTRO_ENABLED=true
EMBRION_ESCAPE_ENABLED=true
EMBRION_ESPIRAL_ENABLED=true
EMBRION_SELF_VERIFIER_ENABLED=true
EMBRION_INPUT_PREVERIFIER_ENABLED=true
EMBRION_BUDGET_TRACKER_ENABLED=true
EMBRION_MAX_THOUGHTS=50
EMBRION_SILENCE_THRESHOLD=300
EMBRION_THINK_COOLDOWN=30
EMBRION_HITL_CHANNEL=telegram
EMBRION_HITL_ESCALATION_THRESHOLD=3
EMBRION_MAX_JUDGE_FAILURES=3
EMBRION_PROPOSAL_TTL_HOURS=24

# ── Planner / Executor ────────────────────────────────────────────────────
PLANNER_MODEL=gpt-4.1
EXECUTOR_MODEL=gpt-4.1
PLANNER_MAX_STEPS=10
PLANNER_MAX_RETRIES=3
PLANNER_STEP_TIMEOUT=120
PLANNER_BUDGET_USD=2.0
PLANNER_MAX_REACT_LOOPS=5
PLANNER_USE_PRODUCT_ARCHITECT=false

# ── Verifier ──────────────────────────────────────────────────────────────
VERIFIER_MODEL=deepseek/deepseek-r1-0528
VERIFIER_BUDGET_USD=1.0
VERIFIER_TIMEOUT_S=60

# ── Budget / Rate Limits ──────────────────────────────────────────────────
DAILY_BUDGET_USD=10.0
DAILY_HARD_LIMIT_USD=50.0
MONTHLY_BUDGET_USD=300.0
MONTHLY_HARD_LIMIT_USD=500.0
BUDGET_HARD_STOP=true
RATE_LIMIT_RPM=60
RATE_LIMIT_RPH=600
BROKER_MAX_CALLS_PER_RUN=20

# ── Anti-Dory ─────────────────────────────────────────────────────────────
ANTI_DORY_ENABLED=true
ANTI_DORY_CONFIDENCE_MIN=0.7
ANTI_DORY_STALENESS_SECONDS=86400
ANTI_DORY_RPC_TIMEOUT_SECONDS=10
ANTI_DORY_RPC_CONNECT_TIMEOUT_SECONDS=5

# ── Cowork (Drift Detection) ─────────────────────────────────────────────
COWORK_DRIFT_ENABLED=true
COWORK_DRIFT_MAX_TURNOS=50
COWORK_DRIFT_MAX_SEGUNDOS=3600
COWORK_DRIFT_MAX_VIOLACIONES=3
COWORK_DRIFT_MAX_CORRECTIVOS=5
COWORK_HOOK_ENABLED=true
COWORK_VETO_ENABLED=true
COWORK_AUTO_DISCIPLINE_ENABLED=false
COWORK_REINJECT_EVERY_N_TURNS=10
COWORK_REINJECT_CTX_THRESHOLD=5000

# ── Catastro (Observability Dashboard) ────────────────────────────────────
CATASTRO_LOG_LEVEL=INFO
CATASTRO_DRY_RUN=false
CATASTRO_SKIP_PERSIST=false
CATASTRO_ENABLE_REASONING=true
CATASTRO_ENABLE_CODING=false
CATASTRO_FAILURE_RATE_THRESHOLD=0.3
CATASTRO_DASHBOARD_REQUIRE_AUTH=true

# ── Alerts ────────────────────────────────────────────────────────────────
ALERT_COOLDOWN_S=300
ALERT_DAILY_COST_USD=10.0
ALERT_ERROR_RATE_PCT=20
ALERT_EVAL_PASS_RATE=70

# ── Feature Flags ─────────────────────────────────────────────────────────
SOVEREIGN_MODE=true
ENABLE_MCP_SERVERS=true
DORY_ORCHESTRATOR_ENABLED=true
BRAND_ENGINE_ENABLED=false
BRAND_ENGINE_MODE=passive
ERROR_MEMORY_EMBEDDINGS=true
ERROR_MEMORY_RECORDING=true
DEBUG=false
