# El Monstruo — Environment Variables
# Copy to .env and fill in your values

# ── LLM API Keys (Los 6 Sabios) ────────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
SONAR_API_KEY=

# ── Supabase (Memory + State) ──────────────────────────────────────
SUPABASE_URL=https://xsumzuhwmivjgftsneov.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xsumzuhwmivjgftsneov.supabase.co:5432/postgres

# ── Telegram Bot ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── LiteLLM (Router) ───────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-monstruo-dev
LITELLM_URL=http://localhost:4000

# ── Langfuse (Observability) ───────────────────────────────────────
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_SECRET=monstruo-langfuse-secret
LANGFUSE_SALT=monstruo-salt-dev

# ── ZeroEntropy (Reranker) ─────────────────────────────────────────
ZEROENTROPY_API_KEY=
# ── ElevenLabs (Voice) ─────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── HeyGen (Video) ─────────────────────────────────────────────────
HEYGEN_API_KEY=

# ── Railway Internal Networking ───────────────────────────────────
# When deployed on Railway, the bot connects to the kernel via:
# KERNEL_API_URL=http://el-monstruo-kernel.railway.internal:8000
# For local development:
KERNEL_API_URL=http://localhost:8000

# ── Application Settings ─────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
DAILY_COST_LIMIT_USD=50.0
