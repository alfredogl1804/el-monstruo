    "hono": "4.12.18",
    "openai": "^6.38.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.10.10",
    "@typescript-eslint/eslint-plugin": "8.34.0",
    "@typescript-eslint/parser": "8.34.0",
    "eslint": "9.16.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.9"
  }
