{
  "name": "@la-forja/api",
  "version": "0.1.0",
  "private": true,
  "description": "La Forja backend — Hono on Railway. Tutor IA Adaptativo + Co-piloto de Sprints + Test Bench. Sprint LA-FORJA-001 v3.2.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
